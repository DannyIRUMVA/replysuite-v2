{
  "name": "replysuite-v2",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "deploy": "nuxt build && npx wrangler pages deploy dist",
    "deploy:training-worker": "npx wrangler deploy --config wrangler.training.toml",
    "tail:training-worker": "npx wrangler tail --config wrangler.training.toml",
    "deploy:media-worker": "npx wrangler deploy --config wrangler.media.toml",
    "tail:media-worker": "npx wrangler tail --config wrangler.media.toml",
    "r2:create:media": "npx wrangler r2 bucket create replysuite-whatsapp-media"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@polar-sh/nuxt": "^0.5.6",
    "@polar-sh/sdk": "^0.47.0",
    "@supabase/supabase-js": "^2.103.0",
    "cheerio": "^1.2.0",
    "gsap": "^3.15.0",
    "marked": "^18.0.2",
    "nuxt": "^4.4.2",
    "pdf-parse-fork": "^1.2.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/scripts": "^1.0.1",
    "@nuxtjs/supabase": "^2.0.5",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/marked": "^5.0.2",
    "@vue/language-core": "^3.2.7",
    "lucide-vue-next": "^1.0.0",
    "wrangler": "^4.81.1"
  }
}
