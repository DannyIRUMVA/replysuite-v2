# ReplySuite example environment
#
# Required = app will usually fail or major features will not work without it.
# Optional = only needed for specific integrations/features.

# ── Public site / app ──────────────────────────────────────────────────────────
# Required
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (core app) ────────────────────────────────────────────────────────
# Required
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta / Instagram / WhatsApp ────────────────────────────────────────────────
# Optional unless using Meta/WhatsApp integrations
INSTAGRAM_APP_ID=
INSTAGRAM_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_VERIFY_TOKEN=
# Secret used by a cron/worker to call POST /api/instagram/poll-comments every minute.
# Keep cron conservative: maxCommentsPerRun=2 and maxCommentAgeMinutes=20 are safer production defaults.
INSTAGRAM_POLL_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_URL=
# Required if WhatsApp uses a different Meta app than Instagram. Used to validate X-Hub-Signature-256.
WHATSAPP_APP_SECRET=

# ── Paypack payments for appointment/booking deposits ─────────────────────────
# Required before saving Paypack credentials. Use a strong random value, 32+ chars.
PAYPACK_SECRET_ENCRYPTION_KEY=

# ── Google Calendar bookings ──────────────────────────────────────────────────
# Required before enabling Google Calendar-backed appointments/bookings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
# Required before storing Google refresh/access tokens. Use a strong random value, 32+ chars.
GOOGLE_TOKEN_ENCRYPTION_KEY=

# ── Widget / embed security ────────────────────────────────────────────────────
# Recommended in production, optional in local development
WIDGET_ACCESS_SECRET=

# ── Training worker dispatch ───────────────────────────────────────────────────
# Optional unless using training queue/worker flow
TRAINING_WORKER_URL=
TRAINING_WORKER_SECRET=

# ── AI providers ───────────────────────────────────────────────────────────────
# GPT-compatible provider selection: azure or openai. Production default is Azure OpenAI.
AI_CHAT_PROVIDER=azure
AI_EMBEDDING_PROVIDER=azure
# Azure OpenAI / Microsoft Foundry. Use the Azure resource root only, e.g. https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
# Must be the Azure chat deployment/model deployment name. Example: gpt-5.5
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.5
# Must be the Azure embedding deployment name. Recommended: text-embedding-3-large with 1536 dimensions.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
# Use preview + v1 for latest GPT-family Azure deployments that require /openai/v1/* endpoints.
AZURE_OPENAI_API_VERSION=preview
AZURE_OPENAI_API_STYLE=v1
# Optional direct OpenAI support for future model/provider swaps.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Polar billing ──────────────────────────────────────────────────────────────
# Optional unless using paid billing flows
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_ORGANIZATION_ID=

# ── SendPulse mailer ───────────────────────────────────────────────────────────
# Optional unless using signup verification / transactional mail
SENDPULSE_ID=
SENDPULSE_SECRET=
SMTP_FROM=
SMTP_FROM_NAME=ReplySuite

# ── Notifications ──────────────────────────────────────────────────────────────
# Optional unless using feedback Slack notifications
SLACK_WEBHOOK_URL=
