# ReplySuite example environment
#
# Required = app will usually fail or major features will not work without it.
# Optional = only needed for specific integrations/features.

# ── Public site / app ──────────────────────────────────────────────────────────
# Required
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (core app) ────────────────────────────────────────────────────────
# Required
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta / Instagram / WhatsApp ────────────────────────────────────────────────
# Optional unless using Meta/WhatsApp integrations
INSTAGRAM_APP_ID=
INSTAGRAM_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_VERIFY_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_URL=

# ── Widget / embed security ────────────────────────────────────────────────────
# Recommended in production, optional in local development
WIDGET_ACCESS_SECRET=

# ── Training worker dispatch ───────────────────────────────────────────────────
# Optional unless using training queue/worker flow
TRAINING_WORKER_URL=
TRAINING_WORKER_SECRET=

# ── AI providers ───────────────────────────────────────────────────────────────
# Required for chatbot replies / embeddings
GEMINI_API_KEY=
# Optional Azure fallback
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# ── Polar billing ──────────────────────────────────────────────────────────────
# Optional unless using paid billing flows
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_ORGANIZATION_ID=

# ── SendPulse mailer ───────────────────────────────────────────────────────────
# Optional unless using signup verification / transactional mail
SENDPULSE_ID=
SENDPULSE_SECRET=
SMTP_FROM=
SMTP_FROM_NAME=ReplySuite

# ── Notifications ──────────────────────────────────────────────────────────────
# Optional unless using feedback Slack notifications
SLACK_WEBHOOK_URL=
